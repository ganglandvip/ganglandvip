# Backend
DATABASE_URL=postgresql+psycopg://postgres:password@db.project-ref.supabase.co:5432/postgres
JWT_SECRET=generate_a_long_random_secret_with_python_secrets_token_urlsafe
JWT_EXPIRE_HOURS=24
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_CLIENTS=10000
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
BIRDEYE_API_KEY=your_birdeye_api_key
BIRDEYE_BASE_URL=https://public-api.birdeye.so
WALLET_TOKEN_SNAPSHOT_LIMIT=20
WALLET_TOKEN_SNAPSHOT_CACHE_SECONDS=3600
ALLOWED_ORIGINS=https://mlmcoin.fun,http://localhost:5173,http://localhost:8080
ENVIRONMENT=production
LOCAL_DEV_DATABASE_URL=sqlite:///./mlmcoin-dev.db

# Frontend
VITE_API_URL=https://api.mlmcoin.fun
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Domains and SSL
DOMAIN=mlmcoin.fun
API_DOMAIN=api.mlmcoin.fun
LETSENCRYPT_EMAIL=admin@mlmcoin.fun

# Supabase project metadata, optional for operations
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Vultr deployment metadata, optional for scripts/operators
VULTR_API_KEY=your_vultr_api_key
VULTR_INSTANCE_ID=your_vultr_instance_id
VULTR_HOST=your_vps_ip_or_hostname
VULTR_USER=root
VULTR_SSH_KEY=~/.ssh/vultr
VULTR_APP_DIR=/opt/mlmcoin

# X profile collection, optional for design-time scripts
X_BEARER_TOKEN=your_x_api_bearer_token
X_SOURCE_USERNAME=mlmcoinfun
X_PROFILE_OUTPUT_DIR=data/x-following-profiles
GITHUB_ACCESS_TOKEN=